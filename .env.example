# Supabase Configuration
# Get these values from your Supabase project settings (https://app.supabase.com)
# API -> Settings -> Project URL and API keys

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public/anonymous key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key (NEVER expose to browser, server-side only)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OAuth / Third-party integrations (optional)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# Payment integrations (optional, for M-Pesa/Stripe setup)
# NEXT_PUBLIC_MPESA_MERCHANT_CODE=
# MPESA_API_KEY=
# MPESA_SHORTCODE=

# App Configuration (optional)
# NEXT_PUBLIC_APP_NAME=Canvus Wholesale
# NEXT_PUBLIC_APP_URL=http://localhost:3000
