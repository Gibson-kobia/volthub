# ═══════════════════════════════════════════════════════════════════════
# Supabase Configuration (REQUIRED FOR PRODUCTION)
# ═══════════════════════════════════════════════════════════════════════
# Get these values from your Supabase project settings
# https://app.supabase.com → Your Project → Settings → API

# Your Supabase project URL (REQUIRED for browser - products, auth, etc.)
# Format: https://xxxxx.supabase.co
# This MUST be set in Vercel Environment Variables for production
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public/anonymous key (REQUIRED for browser)
# Safe to expose in browser (rate-limited + RLS-protected)
# Length: 140+ characters, starts with eyJ
# This MUST be set in Vercel Environment Variables for production
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase service role key (Server-side ONLY, NEVER expose to browser)
# Only needed if using Server Actions or API routes with elevated privileges
# Set only in Vercel Production Environment (not Development/Preview)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ═══════════════════════════════════════════════════════════════════════
# Authentication Callbacks (Optional - for Supabase Auth flows)
# ═══════════════════════════════════════════════════════════════════════
# Set this if you're using email confirmations or password resets
# Format: https://yourdomain.com
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# Third-party Integrations (Optional)
# ═══════════════════════════════════════════════════════════════════════

# Google OAuth (optional)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# GitHub OAuth (optional)
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id

# ═══════════════════════════════════════════════════════════════════════
# Payment Integrations (Optional)
# ═══════════════════════════════════════════════════════════════════════

# M-Pesa / Safaricom Payment Gateway
# MPESA_SHORTCODE=your-merchant-code
# MPESA_API_KEY=your-mpesa-api-key
# MPESA_CONSUMER_KEY=your-consumer-key
# MPESA_CONSUMER_SECRET=your-consumer-secret

# ═══════════════════════════════════════════════════════════════════════
# DEPLOYMENT INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════
# 
# For LOCAL DEVELOPMENT (.env.local):
#   1. Copy this file to .env.local
#   2. Fill in NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
#   3. npm run dev
#
# For VERCEL PRODUCTION (https://vercel.com):
#   1. Go to Vercel Dashboard → volthub project → Settings → Environment Variables
#   2. Add NEXT_PUBLIC_SUPABASE_URL (production value)
#   3. Add NEXT_PUBLIC_SUPABASE_ANON_KEY (production value)
#   4. Optionally add SUPABASE_SERVICE_ROLE_KEY (server-side only)
#   5. Redeploy after adding variables
#
# For VERCEL CORS SETUP:
#   1. Go to https://app.supabase.com → Your Project → Settings → API
#   2. Add to "Authorized Redirect URLs":
#      - https://volthub1.vercel.app
#      - https://volthub1.vercel.app/auth/callback
#   3. Add to "Site URL": https://volthub1.vercel.app
#
# See VERCEL_DEPLOYMENT_GUIDE.md for complete setup instructions
# ═══════════════════════════════════════════════════════════════════════

